# ~/.hermes/notifier.env
# Copia este archivo a ~/.hermes/notifier.env y rellena los valores.
# chmod 0600 ~/.hermes/notifier.env

# ---------------------------------------------------------------------------
# ElevenLabs
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=sk_...

# ID del número Twilio dado de alta en ElevenLabs ConvAI
# (Dashboard ElevenLabs → Conversational AI → Phone numbers)
ELEVENLABS_PHONE_NUMBER_ID=phnum_...

# ---------------------------------------------------------------------------
# Agentes ConvAI — un agent_id por (use_case, idioma)
# ---------------------------------------------------------------------------
HERMES_AGENT_PERSONAL_EN=agent_...
HERMES_AGENT_PERSONAL_ES=agent_...

HERMES_AGENT_SOCIAL_EN=agent_...
HERMES_AGENT_SOCIAL_ES=agent_...

HERMES_AGENT_SERVICE_EN=agent_...
HERMES_AGENT_SERVICE_ES=agent_...

# Idioma por defecto cuando no se puede detectar (en|es)
DEFAULT_LANG=es

# ---------------------------------------------------------------------------
# OpenRouter (resúmenes LLM)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-...

# ---------------------------------------------------------------------------
# Telegram (notificaciones)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN_NOTIFICATIONS=123456:ABC...
TELEGRAM_CHAT_ID_NOTIFICATIONS=123456789
